# ORSGraph API Configuration

# API Server
ORS_API_HOST=127.0.0.1
ORS_API_PORT=8080

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Optional API Key (unset for local development)
# ORS_API_KEY=your_api_key_here

# Zitadel / OIDC Auth
# ORS_AUTH_ENABLED=false
# ORS_AUTH_ISSUER=https://zitadel-production-ff6c.up.railway.app
# ORS_AUTH_AUDIENCE=your_zitadel_client_id_or_api_audience
# ORS_AUTH_ADMIN_ROLE=orsgraph_admin

# Logging
RUST_LOG=info

# Frontend local auth
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=generate_a_long_random_secret
# ZITADEL_ISSUER=https://zitadel-production-ff6c.up.railway.app
# ZITADEL_PROJECT_ID=optional_zitadel_project_id_for_audience_scope
# ZITADEL_CLIENT_ID=your_zitadel_client_id
# ZITADEL_CLIENT_SECRET=your_zitadel_client_secret
# ORS_API_BASE_URL=http://localhost:8080/api/v1
# Optional: full R2/custom-domain release prefix for precomputed public authority JSON.
# ORS_AUTHORITY_HOTSET_BASE_URL=https://authority-hotset.example.com/authority-hotset/release%3Aunversioned
