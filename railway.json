{
  "services": {
    "neo4j": {
      "source": {
        "image": "neo4j:2026.04.0-community"
      },
      "variables": {
        "NEO4J_AUTH": "neo4j/orsgraph2025",
        "NEO4J_dbms_memory_pagecache_size": "1G",
        "NEO4J_dbms_memory_heap_initial__size": "512M",
        "NEO4J_dbms_memory_heap_max__size": "2G"
      }
    },
    "orsgraph-api": {
      "source": {
        "repo": "LastMile-Innovations/ORSGraph",
        "branch": "main",
        "rootDirectory": "crates/orsgraph-api"
      },
      "build": {
        "builder": "RAILPACK"
      },
      "deploy": {
        "startCommand": "./target/release/orsgraph-api",
        "healthcheckPath": "/api/v1/health"
      },
      "variables": {
        "ORS_API_HOST": "0.0.0.0",
        "ORS_API_PORT": "8080",
        "NEO4J_URI": "bolt://neo4j:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "orsgraph2025",
        "VOYAGE_API_KEY": "${{secrets.VOYAGE_API_KEY}}",
        "ORS_RERANK_ENABLED": "true",
        "ORS_RERANK_MODEL": "rerank-2.5",
        "ORS_RERANK_CANDIDATES": "150",
        "ORS_RERANK_TOP_K": "25"
      }
    },
    "frontend": {
      "source": {
        "repo": "LastMile-Innovations/ORSGraph",
        "branch": "main",
        "rootDirectory": "frontend"
      },
      "build": {
        "builder": "RAILPACK"
      },
      "deploy": {
        "startCommand": "npx next start"
      },
      "variables": {
        "NEXT_PUBLIC_API_URL": "${{orsgraph-api.RAILWAY_PUBLIC_DOMAIN}}"
      }
    }
  }
}
