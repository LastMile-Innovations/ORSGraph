{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Cargo.toml",
      "Cargo.lock",
      "Dockerfile",
      "docker-*.sh",
      "crates/orsgraph-api/**",
      "crates/ors-crawler-v0/**",
      "cypher/**",
      "docs/data/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
