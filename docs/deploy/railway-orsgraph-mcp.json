{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.mcp",
    "watchPatterns": [
      "Cargo.toml",
      "Cargo.lock",
      "Dockerfile.mcp",
      "docker-mcp-entrypoint.sh",
      "crates/orsgraph-mcp/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
